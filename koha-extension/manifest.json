{
  "manifest_version": 3,
  "name": "Koha AI Autofill",
  "version": "1.0",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*/cgi-bin/koha/cataloguing/*"],
      "js": ["content.js"]
    }
  ]
}